# Capture360 Environment Variables

# Optional: API endpoints (if you extend Capture360 with backend services)
# PANORAMA_API_URL=https://api.example.com

# Optional: Analytics (if you add tracking)
# ANALYTICS_KEY=your_analytics_key

# Optional: Logging level (development, staging, production)
# LOG_LEVEL=development

# Note: This file is an example. Copy to .env and fill in your values.
# .env files should NEVER be committed to git.
