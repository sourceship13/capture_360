{
  "name": "@sera/capture360",
  "version": "1.0.0",
  "description": "React Native panorama capture and equirectangular stitching with OpenCV",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src",
  "homepage": "https://github.com/sera-tech/capture360#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/sera-tech/capture360.git"
  },
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "src/",
    "lib/",
    "ios/RCTPhotosphereModule.h",
    "ios/RCTPhotosphereModule.mm",
    "ios/Capture360/OpenCVWrapper.h",
    "ios/Capture360/OpenCVWrapper.mm",
    "ios/Capture360/ARCameraView.h",
    "ios/Capture360/ARCameraView.m",
    "ios/Capture360/ARCameraViewManager.m",
    "ios/Capture360/RCTNativeDeviceInfoModule.h",
    "ios/Capture360/RCTNativeDeviceInfoModule.m",
    "ios/Capture360/RCTVideoRecorderModule.h",
    "ios/Capture360/RCTVideoRecorderModule.m",
    "ios/Capture360/RCTModuleProvider.h",
    "ios/Capture360/RCTModuleProvider.m",
    "ios/Capture360/PhotosphereStitcher.m",
    "ios/Capture360/PhotosphereStitcher.swift",
    "ios/Capture360/PrivacyInfo.xcprivacy",
    "android/src/",
    "android/build.gradle",
    "android/gradle.properties",
    "scripts/",
    "capture360.podspec",
    "react-native.config.js"
  ],
  "scripts": {
    "setup:ios": "bash scripts/download-opencv-ios.sh",
    "lint": "eslint src/",
    "prepare": "bob build",
    "prepack": "bob build",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -scheme Capture360 -configuration Release"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "react-native-fs": "^2.20.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "react-native-webview": ">=13.0.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "^15.1.3",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/react": "^19.2.0",
    "@types/react-native-webview": "npm:react-native-webview@^13.16.1",
    "eslint": "^8.57.0",
    "graceful-fs": "^4.2.11",
    "react": "19.2.0",
    "react-native": "0.83.1",
    "react-native-builder-bob": "^0.23.2",
    "react-native-vision-camera": "^4.7.3",
    "react-native-webview": "^13.16.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
}
